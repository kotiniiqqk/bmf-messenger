{
  "name": "@bmf/desktop",
  "private": true,
  "version": "0.3.0",
  "description": "BMF desktop (Electron) — оболочка с авто-обновлением через GitHub Releases.",
  "main": "build/main.js",
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "copy:web": "node scripts/copy-web.mjs",
    "prepare:all": "npm --workspace @bmf/web run build && npm run copy:web && npm run compile",
    "start": "npm run prepare:all && electron .",
    "dist": "npm run prepare:all && electron-builder --publish always",
    "dist:local": "npm run prepare:all && electron-builder --publish never"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3"
  },
  "build": {
    "appId": "ink.bmf.app",
    "productName": "BMF",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "build/**/*",
      "renderer/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "kotiniiqqk",
        "repo": "bmf-messenger"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
